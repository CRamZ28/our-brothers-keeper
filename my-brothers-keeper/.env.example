# =============================================================
# Our Brother's Keeper - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# =============================================================

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Full PostgreSQL connection string (Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/our_brothers_keeper

# ── Authentication ────────────────────────────────────────────
# A long, random secret used to sign session cookies
SESSION_SECRET=change-this-to-a-secure-random-string-in-production

# For production, add your chosen OIDC / OAuth provider credentials here:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Owner user ID (used for initial admin bootstrapping)
OWNER_OPEN_ID=

# ── Object / File Storage ─────────────────────────────────────
# In development, files are stored in the local uploads/ directory.
# For production, use AWS S3, Cloudflare R2, or any S3-compatible provider:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket-name
# S3_ENDPOINT=  (only needed for R2 / MinIO)

# ── Email (Resend) ────────────────────────────────────────────
# Sign up at https://resend.com — emails are sent from notifications@obkapp.com
# You will need to verify a sending domain if changing FROM address.
RESEND_API_KEY=re_your_resend_api_key_here

# ── App Metadata (Vite frontend) ──────────────────────────────
VITE_APP_TITLE=Our Brother's Keeper
VITE_APP_LOGO=/obk-logo.png

# ── Optional: Error Tracking (Sentry) ────────────────────────
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# ── Optional: Analytics ───────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
