# =============================================================
# Our Brother's Keeper - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# =============================================================

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/our_brothers_keeper

# ── Authentication ────────────────────────────────────────────
# A long, random secret used to sign session cookies
SESSION_SECRET=change-this-to-a-secure-random-string-in-production

# --- Replit Auth (used on Replit only) ---
# These are injected automatically by Replit; set them manually if self-hosting
# and replacing replitAuth.ts with your own auth provider.
ISSUER_URL=https://replit.com/oidc
REPLIT_DOMAINS=your-repl-domain.replit.dev
REPL_ID=your-repl-id
OWNER_OPEN_ID=

# ── Object / File Storage ─────────────────────────────────────
# --- Replit Object Storage (used on Replit only) ---
# The sidecar and bucket dir are provided automatically by Replit.
# When self-hosting, replace objectStorage.ts with AWS S3, Cloudflare R2,
# or any S3-compatible provider and supply credentials here instead.
PRIVATE_OBJECT_DIR=/your-bucket-name
# REPLIT_SIDECAR_ENDPOINT is set automatically by Replit; not needed when self-hosting.

# --- AWS S3 / S3-compatible (for self-hosted deployments) ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket-name

# ── Email (Resend) ────────────────────────────────────────────
# Sign up at https://resend.com — emails are sent from notifications@obkapp.com
# You will need to verify a sending domain if changing FROM address.
RESEND_API_KEY=re_your_resend_api_key_here

# ── App Metadata (Vite frontend) ──────────────────────────────
VITE_APP_TITLE=Our Brother's Keeper
VITE_APP_LOGO=/obk-logo.png

# ── Optional: Analytics ───────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Optional: Forge API ───────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
